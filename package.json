{
  "name": "sentinel",
  "version": "0.1.0",
  "description": "Browser-native AI security layer — detects and redacts sensitive data and prompt-injection attacks before they reach any LLM.",
  "type": "module",
  "private": true,
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "build:engine": "node scripts/build-engine.mjs",
    "build:dashboard": "vite build --config dashboard/vite.config.js",
    "build": "npm run build:engine && npm run build:dashboard"
  },
  "keywords": [
    "security",
    "llm",
    "aho-corasick",
    "trie",
    "prompt-injection",
    "chrome-extension",
    "privacy"
  ],
  "author": "alirizzzv",
  "license": "MIT",
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "esbuild": "^0.28.0",
    "vite": "^5.4.21",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.3.1"
  }
}
